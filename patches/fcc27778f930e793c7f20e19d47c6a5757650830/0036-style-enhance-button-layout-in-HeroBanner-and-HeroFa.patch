From 6c4da686d94adf74c045ae01cc24d59a1250bea4 Mon Sep 17 00:00:00 2001
From: Sina Hatamian <sina.hatamian75@gmail.com>
Date: Wed, 20 May 2026 17:07:44 +0330
Subject: [PATCH 36/89] style: enhance button layout in HeroBanner and
 HeroFallback components for improved responsiveness and visual consistency

---
 resources/css/app.css                    | 2 ++
 resources/js/components/HeroBanner.vue   | 2 +-
 resources/js/components/HeroFallback.vue | 2 +-
 3 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/resources/css/app.css b/resources/css/app.css
index 84905d0..1c09895 100644
--- a/resources/css/app.css
+++ b/resources/css/app.css
@@ -2,6 +2,8 @@
 @import 'tw-animate-css';
 @import url('https://fonts.googleapis.com/css2?family=Marcellus+SC&display=swap');
 @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');
+/** Ensures Vue templates are scanned so arbitrary utilities (e.g. hero CTA) exist in prod CSS. */
+@source '../js/**/*.vue';
 @source '../../vendor/laravel/framework/src/Illuminate/Pagination/resources/views/*.blade.php';
 @source '../../storage/framework/views/*.php';
 
diff --git a/resources/js/components/HeroBanner.vue b/resources/js/components/HeroBanner.vue
index 7568be0..5f2eefb 100644
--- a/resources/js/components/HeroBanner.vue
+++ b/resources/js/components/HeroBanner.vue
@@ -105,7 +105,7 @@ const heroTeaserLines = computed((): [string, string] | null => {
                                 severity="primary"
                                 type="internal-link"
                                 :href="storyUrl"
-                                class="begin-btn font-[Inter] !h-[53px] w-full max-w-[284px] px-8 text-[16px] font-medium leading-normal text-black"
+                                class="begin-btn font-[Inter] !box-border !flex !h-auto !min-h-[53px] w-full max-w-[284px] items-center justify-center overflow-visible whitespace-nowrap px-8 py-3 text-[16px] font-medium !leading-none text-black"
                             >
                                 Begin Your Journey
                             </BaseButton>
diff --git a/resources/js/components/HeroFallback.vue b/resources/js/components/HeroFallback.vue
index a20e8ec..97ca415 100644
--- a/resources/js/components/HeroFallback.vue
+++ b/resources/js/components/HeroFallback.vue
@@ -60,7 +60,7 @@ import { index as storiesIndex } from '@/wayfinder/routes/stories';
                                 severity="primary"
                                 type="internal-link"
                                 :href="storiesIndex().url"
-                                class="begin-btn font-[Inter] !h-[53px] w-full max-w-[284px] px-8 text-[16px] font-medium leading-normal text-black"
+                                class="begin-btn font-[Inter] !box-border !flex !h-auto !min-h-[53px] w-full max-w-[284px] items-center justify-center overflow-visible whitespace-nowrap px-8 py-3 text-[16px] font-medium !leading-none text-black"
                             >
                                 Begin Your Journey
                             </BaseButton>
-- 
