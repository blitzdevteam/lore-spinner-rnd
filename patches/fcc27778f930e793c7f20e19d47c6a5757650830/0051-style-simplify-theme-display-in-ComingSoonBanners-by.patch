From f780a9a8201462a7e27b3cb4cf488128ebac9346 Mon Sep 17 00:00:00 2001
From: Sina Hatamian <sina.hatamian75@gmail.com>
Date: Sun, 24 May 2026 16:56:10 +0330
Subject: [PATCH 51/89] style: simplify theme display in ComingSoonBanners by
 joining themes into a single line

---
 resources/js/components/ComingSoonBanners.vue | 9 +++------
 1 file changed, 3 insertions(+), 6 deletions(-)

diff --git a/resources/js/components/ComingSoonBanners.vue b/resources/js/components/ComingSoonBanners.vue
index 8a4fcc9..5a44e28 100644
--- a/resources/js/components/ComingSoonBanners.vue
+++ b/resources/js/components/ComingSoonBanners.vue
@@ -237,12 +237,9 @@ const hoveredCard = computed(() => cards.find((c) => c.id === hoveredId.value) ?
                                     <p class="text-[20px] font-medium leading-normal text-white">
                                         {{ hoveredCard.title }}
                                     </p>
-                                    <div class="flex flex-wrap items-center gap-[4px] text-[14px] leading-normal text-white">
-                                        <template v-for="theme in hoveredCard.themes" :key="theme">
-                                            <span class="size-[6px] shrink-0 rounded-full bg-primary" />
-                                            <span>{{ theme }}</span>
-                                        </template>
-                                    </div>
+                                    <p class="text-[14px] leading-normal text-white">
+                                        {{ hoveredCard.themes.join(' | ') }}
+                                    </p>
                                 </div>
                             </div>
                         </div>
-- 
